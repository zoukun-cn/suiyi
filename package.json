{
  "name": "suiyi",
  "displayName": "随译 - 双语对照翻译插件",
  "version": "0.0.1",
  "description": "一款支持双语对照、划词翻译、悬停翻译的浏览器翻译插件",
  "author": "zoukun",
  "scripts": {
    "dev": "plasmo dev",
    "dev:firefox": "plasmo dev --target=firefox-mv2",
    "build": "plasmo build",
    "build:firefox": "plasmo build --target=firefox-mv2",
    "package": "plasmo package",
    "clean": "rm -rf build .plasmo"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.13.0",
    "clsx": "^2.1.1",
    "plasmo": "latest",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "lmdb",
      "msgpackr-extract",
      "sharp"
    ]
  },
  "manifest": {
    "host_permissions": [
      "https://*/*",
      "http://*/*"
    ],
    "permissions": [
      "storage",
      "activeTab",
      "sidePanel",
      "scripting",
      "tabs",
      "contextMenus"
    ]
  }
}
